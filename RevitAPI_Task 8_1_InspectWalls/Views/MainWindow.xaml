<Window x:Class="RevitAPI_Task_8_1_InspectWalls.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RevitAPI_Task_8_1_InspectWalls.Views"
        xmlns:viewModels="clr-namespace:RevitAPI_Task_8_1_InspectWalls.ViewModels"
        d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel}"
        mc:Ignorable="d"
        Title="Анализ геометрии стен" 
        Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Кнопка выбора стены -->
        <Button Grid.Row="0" 
                Content="Выбрать стену"
                Command="{Binding SelectWallCommand}"
                Height="40"
                Margin="0,0,0,15"
                FontSize="14"
                Background="#2196F3"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"/>

        <!-- Информация о стене -->
        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="5" 
                Padding="10"
                Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Информация о стене" 
                           FontWeight="Bold" 
                           FontSize="14"
                           Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Имя стены: " Margin="0,0,5,5"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding WallInfo.Name}" 
                               FontWeight="SemiBold" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Тип: " Margin="0,0,5,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WallInfo.Type}" 
                               FontWeight="SemiBold"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Геометрические параметры -->
        <Border Grid.Row="2" 
                Background="White" 
                CornerRadius="5" 
                Padding="10"
                Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Геометрические параметры" 
                           FontWeight="Bold" 
                           FontSize="14"
                           Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Длина: " Margin="0,0,5,5"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" 
                               Text="{Binding WallInfo.Length, StringFormat='{}{0:F2} мм'}" 
                               FontWeight="SemiBold" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Высота: " Margin="0,0,5,5"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" 
                               Text="{Binding WallInfo.Height, StringFormat='{}{0:F2} мм'}" 
                               FontWeight="SemiBold" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Толщина: " Margin="0,0,5,5"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" 
                               Text="{Binding WallInfo.Thickness, StringFormat='{}{0:F2} мм'}" 
                               FontWeight="SemiBold" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Объём: " Margin="0,0,5,5"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" 
                               Text="{Binding WallInfo.Volume, StringFormat='{}{0:F3} м³'}" 
                               FontWeight="SemiBold" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Площадь: " Margin="0,0,5,0"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" 
                               Text="{Binding WallInfo.Area, StringFormat='{}{0:F2} м²'}" 
                               FontWeight="SemiBold"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Контроль толщины с индикатором-кружком -->
        <Border Grid.Row="3" 
                Background="White" 
                CornerRadius="5" 
                Padding="10"
                Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Контроль толщины" 
                           FontWeight="Bold" 
                           FontSize="14"
                           Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Предел толщины -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Предел толщины: " 
                               VerticalAlignment="Center" Margin="0,0,5,10"/>

                    <TextBox Grid.Row="0" Grid.Column="1" 
                             Text="{Binding ThicknessLimit, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,5,10"
                             Padding="5,3"
                             VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="мм" 
                               VerticalAlignment="Center" Margin="0,0,0,10"/>

                    <!-- Статус с индикатором -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Статус: " 
                               VerticalAlignment="Center" Margin="0,0,5,0"/>

                    <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">

                        <TextBlock Text="{Binding StatusText}" 
                                   FontWeight="Bold"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>

                        <!-- Индикатор-кружок с триггерами прямо здесь -->
                        <Ellipse Width="14" 
                                 Height="14" 
                                 Margin="4,0,0,0"
                                 VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="Gray"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WallInfo.IsCorrect}" Value="True">
                                            <Setter Property="Fill" Value="#44FF44"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding WallInfo.IsCorrect}" Value="False">
                                            <Setter Property="Fill" Value="#FF4444"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>